generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String        @id @default(cuid())
  telegramId String        @unique
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  raffleEntries RaffleEntry[]
  raffleWins    RaffleRound[] @relation("RaffleWinner")
  caseOpenings  CaseOpening[]
}

model RaffleRound {
  id             String        @id @default(cuid())
  status         RaffleStatus  @default(BETTING)
  startedAt      DateTime      @default(now())
  bettingEndsAt  DateTime
  spinningEndsAt DateTime?
  finishedAt     DateTime?
  totalPool      Int           @default(0)
  winnerUserId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  winner  User?          @relation("RaffleWinner", fields: [winnerUserId], references: [id])
  entries RaffleEntry[]

  @@index([status])
}

model RaffleEntry {
  id        String      @id @default(cuid())
  roundId   String
  userId    String
  amount    Int
  createdAt DateTime    @default(now())

  round     RaffleRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([userId])
}

model CaseOpening {
  id               String           @id @default(cuid())
  caseSlug         String
  caseName         String
  priceTon         Int
  rewardId         String
  rewardName       String
  rewardImage      String
  rewardRarity     CaseRewardRarity
  rewardChance     Int
  rewardValueLabel String
  userId           String?
  createdAt        DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([caseSlug])
  @@index([userId])
  @@index([createdAt])
}

enum RaffleStatus {
  BETTING
  SPINNING
  FINISHED
}

enum CaseRewardRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}
