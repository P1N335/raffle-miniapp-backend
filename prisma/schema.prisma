generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(cuid())
  telegramId           String            @unique
  username             String?
  firstName            String?
  lastName             String?
  photoUrl             String?
  balanceTon           Int               @default(0)
  tonWalletAddress     String?           @unique
  tonWalletAddressRaw  String?           @unique
  tonWalletNetwork     TonNetwork?
  tonWalletConnectedAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  raffleEntries      RaffleEntry[]
  raffleWins         RaffleRound[]      @relation("RaffleWinner")
  caseOpenings       CaseOpening[]
  casePaymentIntents CasePaymentIntent[]
  createdCoinflipRooms CoinflipRoom[]   @relation("CoinflipCreator")
  joinedCoinflipRooms  CoinflipRoom[]   @relation("CoinflipOpponent")
  wonCoinflipRooms     CoinflipRoom[]   @relation("CoinflipWinner")
  coinflipRoomItems    CoinflipRoomItem[]
  authSessions         AuthSession[]
  balanceTransactions  BalanceTransaction[]
  auditLogs            AuditLog[]
  giftPurchaseRequests GiftPurchaseRequest[]
}

model RaffleRound {
  id             String        @id @default(cuid())
  status         RaffleStatus  @default(BETTING)
  startedAt      DateTime      @default(now())
  bettingEndsAt  DateTime
  spinningEndsAt DateTime?
  finishedAt     DateTime?
  totalPool      Int           @default(0)
  winnerUserId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  winner  User?          @relation("RaffleWinner", fields: [winnerUserId], references: [id])
  entries RaffleEntry[]

  @@index([status])
}

model RaffleEntry {
  id        String      @id @default(cuid())
  roundId   String
  userId    String
  amount    Int
  createdAt DateTime    @default(now())

  round     RaffleRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([userId])
}

model GiftType {
  id                 String           @id
  telegramGiftTypeId String?
  name               String
  description        String?
  image              String
  rarity             CaseRewardRarity
  estimatedValueTon  Int
  valueLabel         String
  accent             String
  textColor          String
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  caseDrops    CaseDrop[]
  caseOpenings CaseOpening[]
  coinflipRoomItems CoinflipRoomItem[]
  giftPurchaseRequests GiftPurchaseRequest[]
}

model CaseDefinition {
  id              String            @id
  slug            String            @unique
  name            String
  tagline         String
  shortDescription String
  priceTon        Int
  image           String
  badgeGradient   String
  buttonGradient  String
  surfaceTint     String
  sortOrder       Int               @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  drops              CaseDrop[]
  caseOpenings       CaseOpening[]
  casePaymentIntents CasePaymentIntent[]

  @@index([slug])
  @@index([isActive, sortOrder])
}

model CaseDrop {
  id         String         @id
  caseId     String
  giftTypeId String
  chance     Int
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  case        CaseDefinition @relation(fields: [caseId], references: [id], onDelete: Restrict)
  giftType    GiftType       @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)
  caseOpenings CaseOpening[]

  @@unique([caseId, giftTypeId])
  @@index([caseId, sortOrder])
  @@index([giftTypeId])
}

model CasePaymentIntent {
  id                  String            @id @default(cuid())
  userId              String?
  caseId              String
  caseSlug            String
  caseName            String
  paymentSource       CasePaymentSource @default(TON_WALLET)
  walletAddress       String
  walletAddressRaw    String
  recipientAddress    String
  recipientAddressRaw String
  amountTon           Int
  amountNano          String
  reference           String            @unique
  status              CasePaymentStatus @default(PENDING)
  submittedBoc        String?
  transactionHash     String?
  transactionLt       String?
  validUntil          DateTime
  confirmedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  case    CaseDefinition  @relation(fields: [caseId], references: [id], onDelete: Restrict)
  opening CaseOpening?

  @@index([userId])
  @@index([caseId])
  @@index([status, validUntil])
  @@index([walletAddressRaw])
}

model CaseOpening {
  id                    String            @id @default(cuid())
  userId                String?
  caseId                String
  caseDropId            String
  giftTypeId            String
  paymentIntentId       String            @unique
  status                CaseOpeningStatus @default(OWNED)
  telegramOwnedGiftId   String?
  withdrawFailureReason String?
  soldAmountTon         Int?
  soldAt                DateTime?
  withdrawalRequestedAt DateTime?
  withdrawnAt           DateTime?
  createdAt             DateTime          @default(now())

  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  case          CaseDefinition    @relation(fields: [caseId], references: [id], onDelete: Restrict)
  caseDrop      CaseDrop          @relation(fields: [caseDropId], references: [id], onDelete: Restrict)
  giftType      GiftType          @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)
  paymentIntent CasePaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  coinflipRoomItems CoinflipRoomItem[]
  giftPurchaseRequest GiftPurchaseRequest?

  @@index([caseId])
  @@index([caseDropId])
  @@index([giftTypeId])
  @@index([userId])
  @@index([createdAt])
}

model CoinflipRoom {
  id              String             @id @default(cuid())
  roomCode        String             @unique
  status          CoinflipRoomStatus @default(OPEN)
  creatorUserId   String
  opponentUserId  String?
  winnerUserId    String?
  creatorTotalTon Int
  opponentTotalTon Int?
  creatorReadyAt  DateTime
  opponentReadyAt DateTime?
  finishedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  creator  User              @relation("CoinflipCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  opponent User?             @relation("CoinflipOpponent", fields: [opponentUserId], references: [id], onDelete: SetNull)
  winner   User?             @relation("CoinflipWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  items    CoinflipRoomItem[]

  @@index([status, createdAt])
  @@index([creatorUserId, status])
  @@index([opponentUserId])
  @@index([winnerUserId])
}

model CoinflipRoomItem {
  id                String       @id @default(cuid())
  roomId            String
  userId            String
  openingId         String
  giftTypeId        String
  seat              CoinflipSeat
  estimatedValueTon Int
  createdAt         DateTime     @default(now())

  room     CoinflipRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  opening  CaseOpening  @relation(fields: [openingId], references: [id], onDelete: Restrict)
  giftType GiftType     @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)

  @@unique([roomId, openingId])
  @@index([roomId, seat])
  @@index([openingId])
  @@index([userId])
}

model AuthSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model BalanceTransaction {
  id             String                 @id @default(cuid())
  userId         String
  type           BalanceTransactionType
  amountTon      Int
  balanceAfterTon Int
  referenceType  String?
  referenceId    String?
  note           String?
  createdAt      DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  requestPath String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model GiftPurchaseRequest {
  id                    String             @id @default(cuid())
  userId                String
  openingId             String             @unique
  giftTypeId            String
  status                GiftPurchaseStatus @default(QUEUED)
  providerKey           String?
  providerLabel         String?
  searchQuery           String
  externalListingId     String?
  externalListingUrl    String?
  externalOrderId       String?
  quotedPriceTon        Int?
  purchasedPriceTon     Int?
  deliveryTelegramGiftId String?
  failureReason         String?
  adminNote             String?
  metadata              Json?
  queuedAt              DateTime           @default(now())
  searchStartedAt       DateTime?
  offerFoundAt          DateTime?
  purchasedAt           DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  updatedAt             DateTime           @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opening  CaseOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  giftType GiftType    @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)

  @@index([userId, queuedAt])
  @@index([status, queuedAt])
  @@index([giftTypeId, status])
}

enum RaffleStatus {
  BETTING
  SPINNING
  FINISHED
}

enum CaseRewardRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum CasePaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  EXPIRED
  FAILED
}

enum CasePaymentSource {
  TON_WALLET
  INTERNAL_BALANCE
}

enum TonNetwork {
  MAINNET
  TESTNET
}

enum CaseOpeningStatus {
  OWNED
  IN_COINFLIP
  SOLD
  WITHDRAW_PENDING
  WITHDRAWN
}

enum CoinflipRoomStatus {
  OPEN
  FINISHED
  CANCELLED
}

enum CoinflipSeat {
  CREATOR
  OPPONENT
}

enum BalanceTransactionType {
  INVENTORY_SALE
  CASE_OPENING
  ADMIN_CREDIT
  ADMIN_DEBIT
}

enum GiftPurchaseStatus {
  QUEUED
  SEARCHING
  OFFER_FOUND
  PURCHASE_PENDING
  PURCHASED
  DELIVERY_PENDING
  DELIVERED
  FAILED
  CANCELLED
}
