generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(cuid())
  telegramId           String            @unique
  username             String?
  firstName            String?
  lastName             String?
  photoUrl             String?
  tonWalletAddress     String?           @unique
  tonWalletAddressRaw  String?           @unique
  tonWalletNetwork     TonNetwork?
  tonWalletConnectedAt DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  raffleEntries      RaffleEntry[]
  raffleWins         RaffleRound[]      @relation("RaffleWinner")
  caseOpenings       CaseOpening[]
  casePaymentIntents CasePaymentIntent[]
}

model RaffleRound {
  id             String        @id @default(cuid())
  status         RaffleStatus  @default(BETTING)
  startedAt      DateTime      @default(now())
  bettingEndsAt  DateTime
  spinningEndsAt DateTime?
  finishedAt     DateTime?
  totalPool      Int           @default(0)
  winnerUserId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  winner  User?          @relation("RaffleWinner", fields: [winnerUserId], references: [id])
  entries RaffleEntry[]

  @@index([status])
}

model RaffleEntry {
  id        String      @id @default(cuid())
  roundId   String
  userId    String
  amount    Int
  createdAt DateTime    @default(now())

  round     RaffleRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([userId])
}

model GiftType {
  id                 String           @id
  telegramGiftTypeId String?
  name               String
  description        String?
  image              String
  rarity             CaseRewardRarity
  estimatedValueTon  Int
  valueLabel         String
  accent             String
  textColor          String
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  caseDrops    CaseDrop[]
  caseOpenings CaseOpening[]
}

model CaseDefinition {
  id              String            @id
  slug            String            @unique
  name            String
  tagline         String
  shortDescription String
  priceTon        Int
  image           String
  badgeGradient   String
  buttonGradient  String
  surfaceTint     String
  sortOrder       Int               @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  drops              CaseDrop[]
  caseOpenings       CaseOpening[]
  casePaymentIntents CasePaymentIntent[]

  @@index([slug])
  @@index([isActive, sortOrder])
}

model CaseDrop {
  id         String         @id
  caseId     String
  giftTypeId String
  chance     Int
  sortOrder  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  case        CaseDefinition @relation(fields: [caseId], references: [id], onDelete: Restrict)
  giftType    GiftType       @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)
  caseOpenings CaseOpening[]

  @@unique([caseId, giftTypeId])
  @@index([caseId, sortOrder])
  @@index([giftTypeId])
}

model CasePaymentIntent {
  id                  String            @id @default(cuid())
  userId              String?
  caseId              String
  caseSlug            String
  caseName            String
  walletAddress       String
  walletAddressRaw    String
  recipientAddress    String
  recipientAddressRaw String
  amountTon           Int
  amountNano          String
  reference           String            @unique
  status              CasePaymentStatus @default(PENDING)
  submittedBoc        String?
  transactionHash     String?
  transactionLt       String?
  validUntil          DateTime
  confirmedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  case    CaseDefinition  @relation(fields: [caseId], references: [id], onDelete: Restrict)
  opening CaseOpening?

  @@index([userId])
  @@index([caseId])
  @@index([status, validUntil])
  @@index([walletAddressRaw])
}

model CaseOpening {
  id                    String            @id @default(cuid())
  userId                String?
  caseId                String
  caseDropId            String
  giftTypeId            String
  paymentIntentId       String            @unique
  status                CaseOpeningStatus @default(OWNED)
  telegramOwnedGiftId   String?
  withdrawFailureReason String?
  soldAmountTon         Int?
  soldAt                DateTime?
  withdrawalRequestedAt DateTime?
  withdrawnAt           DateTime?
  createdAt             DateTime          @default(now())

  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  case          CaseDefinition    @relation(fields: [caseId], references: [id], onDelete: Restrict)
  caseDrop      CaseDrop          @relation(fields: [caseDropId], references: [id], onDelete: Restrict)
  giftType      GiftType          @relation(fields: [giftTypeId], references: [id], onDelete: Restrict)
  paymentIntent CasePaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseDropId])
  @@index([giftTypeId])
  @@index([userId])
  @@index([createdAt])
}

enum RaffleStatus {
  BETTING
  SPINNING
  FINISHED
}

enum CaseRewardRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum CasePaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  EXPIRED
  FAILED
}

enum TonNetwork {
  MAINNET
  TESTNET
}

enum CaseOpeningStatus {
  OWNED
  SOLD
  WITHDRAW_PENDING
  WITHDRAWN
}
